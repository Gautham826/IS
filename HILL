#include <stdio.h>

int main()
{
    int k[3][3],a[3],i,j;
    char t[20];
    scanf("%s",t);
    for(i=0;i<3;i++){
        for(j=0;j<3;j++){
            scanf("%d",&k[i][j]);
        }
    }
    
    for(i=0;t[i];i+=3){
        for(j=0;j<3;j++){
            a[j]=k[j][0]*(t[i]-65)+k[j][1]*(t[i+1]-65)+k[j][2]*(t[i+2]-65);
        }
    }
    
    for(j=0;j<3;j++){
        printf("%c",(a[j]%26)+65);
    }
    return 0;
}
